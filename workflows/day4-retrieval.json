    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nif (input.skip_llm) {\n return [{json: {\n question: input.question,\n language: input.language,\n answer: \"I could not find this information in the company knowledge base.\",\n sources: [],\n timestamp: new Date().toISOString()\n }}];\n}\nconst answer = $json.candidates[0].content.parts[0].text;\nconst question = $('Build Retrieval Context').first().json.question;\nconst sources = $('Build Retrieval Context').first().json.sources;\nconst language = $('Build Retrieval Context').first().json.language;\n\nreturn [\n {\n json:{\n question,\n language,\n answer,\n sources,\n timestamp: new Date().toISOString()\n }\n }\n];"
      },
