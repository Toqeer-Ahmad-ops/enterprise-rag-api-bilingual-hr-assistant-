    {
      "parameters": {
        "jsCode": "const docs = $json.body;\nif (!docs || docs.length === 0) {\n return [{json: {question: $('Webhook').first().json.body.question, context: '', sources: [], skip_llm: true}}];\n}\nconst context = docs\n.map((doc, index) => {\n return `Source ${index + 1} (similarity: ${doc.similarity.toFixed(3)}):\\n${doc.content}`;\n })\n.join('\\n\\n');\n\nreturn [\n {\n json: {\n question: $('Webhook').first().json.body.question,\n context,\n sources: docs.map(doc => ({\n id: doc.id,\n similarity: doc.similarity\n })),\nlanguage: docs[0].language, \nskip_llm: docs[0].similarity < 0.7\n }\n }\n];"
      },
