        "jsCode": "const embedding = $json.embedding;\nif (!embedding?.values || embedding.values.length!== 768) {\n throw new Error('Invalid embedding dimension. Expected 768, got ${embedding?.value?.length ?? 0}'\n);\n}\nreturn [{\n  json:{\n embedding_length: embedding.values.length,\n embedding: embedding.values,\n  },\n },\n];"
