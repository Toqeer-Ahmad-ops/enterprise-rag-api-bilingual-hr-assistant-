      ],
      "id": "08bc2ed9-bfe5-4bbc-9e4e-055a7c6045ef",
      "name": "Generate Document Embedding",
      "retryOnFail": true,
      "waitBetweenTries": 2000,
      "credentials": {
        "googlePalmApi": {
          "id": "V7LLvidI6N7DOpcZ",
          "name": "Gemini Toqeer Prod"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.body?.content || \"\";\n\nif (!text) {\n  throw new Error(\"No text provided.\");\n}\n\nif (!$json.body?.doc_id) {\n    throw new Error (\"No doc_id provided.\");\n  \n}\nconst docId = $json.body?.doc_id || \"\";\nconst title = $json.body?.title || \"\";\n\nconst chunkSize = 1000;\nconst overlap = 200;\n\nconst isArabic = /[\\u0600-\\u06FF]/.test(text);\n\nconst chunks = [];\n\nlet chunkId = 1;\n\nfor (let i = 0; i < text.length; i += chunkSize - overlap) {\n\n  const end = Math.min(i + chunkSize, text.length);\n\n  chunks.push({\n    json: {\n      doc_id: docId,\n      chunk_id: chunkId++,\n      title: title,\n      chunk: text.slice(i, end),\n      language: isArabic ? \"ar\" : \"en\",\n      supported_languages: [\"en\", \"ar\"]\n    }\n  });\n\n}\n\nreturn chunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
